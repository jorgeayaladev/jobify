############################################################

# ROOT .gitignore (Django + Next.js + Docker + pnpm)

############################################################

############################

# 🔐 Environment variables

############################
.env
.env.*
!.env.example

############################

# 🐳 Docker

############################
docker-compose.override.yml
*.pid
*.seed

############################

# 🗄️ PostgreSQL / pgAdmin

############################
postgres_data/
pgadmin_data/

############################

# 🐍 Python / Django (backend)

############################
**pycache**/
*.py[cod]
*.pyo
*.pyd
*.sqlite3
db.sqlite3
*.log

# Virtual environments

venv/
env/
.venv/

# Django static & media

staticfiles/
media/

############################

# ⚛️ Next.js / Node (frontend)

############################
node_modules/
.pnpm-store/
.next/
out/
dist/
build/

# Logs

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

############################

# 🧪 Testing

############################
coverage/
.nyc_output/
*.coverage

############################

# 🧠 TypeScript

############################
*.tsbuildinfo

############################

# 🧹 Cache

############################
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.turbo/

############################

# 🧰 IDE / Editor

############################
.vscode/
.idea/
*.swp
*.swo
*~

############################

# 🌐 OS files

############################
.DS_Store
Thumbs.db
Desktop.ini

############################

# 🔐 Keys & secrets

############################
*.pem
*.key

############################

# 📦 Misc

############################
*.tgz

############################

# 📚 Docs (optional)

############################

# docs/build/

############################################################

# END

